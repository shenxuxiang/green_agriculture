<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--  AlertWidget 组件动画定义  -->
    <style name="AlertWidgetAnimation">
        <item name="android:windowEnterAnimation">@anim/alert_widget_enter_anim</item>
        <item name="android:windowExitAnimation">@anim/alert_widget_exit_anim</item>
    </style>


    <!--  BottomSheet 组件动画定义  -->
    <!--    <style name="BottomMadalAnimation">-->
    <!--        <item name="android:windowEnterAnimation">@anim/bottom_sheet_modal_enter_anim</item>-->
    <!--        <item name="android:windowExitAnimation">@anim/bottom_sheet_modal_exit_anim</item>-->
    <!--    </style>-->

    <!--  AlertWidget 自定义主题样式  -->
    <style name="AlertWidgetDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowMinWidthMinor">100%</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/AlertWidgetAnimation</item>
    </style>

    <style name="LoadingDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowMinWidthMinor">0%</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/AlertWidgetAnimation</item>
    </style>

    <style name="LoginInputPlaceholderTextAppearance" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="ButtonWidgetTextAppearance" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">normal</item>
    </style>

    <style name="BottomSheetWidgetTheme" parent="Theme.Design.BottomSheetDialog">
        <!-- 浮动窗口无法独立修改导航栏颜色，所以必须要设置为 false -->
        <item name="android:windowIsFloating">false</item>
        <!-- 修改底部状态栏的背景色 -->
        <item name="android:navigationBarColor">@color/white</item>
        <!-- 让 BottomSheet 的默认背景透明 -->
        <item name="bottomSheetStyle">@style/BottomSheetWidgetThemeStyle</item>
    </style>

    <style name="BottomSheetWidgetThemeStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>