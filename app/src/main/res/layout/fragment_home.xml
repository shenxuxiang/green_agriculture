<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="outerViewPager"
            type="androidx.viewpager2.widget.ViewPager2" />

        <variable
            name="viewModel"
            type="com.example.green_agriculture.pages.home.HomeViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".pages.home.HomeFragment">

        <com.example.green_agriculture.components.ToolbarWidget
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:title="@{`首页`}" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <com.example.green_agriculture.components.SwiperWidget
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    app:index="@{0}"
                    app:interval="@{3000}"
                    app:options="@{viewModel.uiState.swiperList}"
                    app:outer_view_pager="@{outerViewPager}" />

                <com.example.green_agriculture.pages.home.components.MenuWidget
                    android:id="@+id/menuBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="10dp"
                    android:columnCount="4"
                    android:paddingVertical="20dp"
                    app:menuOptions="@{viewModel.uiState.menuOptions}" />

                <com.example.green_agriculture.components.ModuleTitleWidget
                    hasMore="@{false}"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"
                    app:title="@{`农业咨询`}" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="30dp"
                    android:backgroundTint="@color/primary"
                    android:hapticFeedbackEnabled="true"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Show Toast"
                    app:cornerRadius="20dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>