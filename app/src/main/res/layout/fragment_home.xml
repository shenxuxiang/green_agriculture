<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="outerViewPager"
            type="androidx.viewpager2.widget.ViewPager2" />

        <variable
            name="viewModel"
            type="com.example.green_agriculture.pages.home.HomeViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".pages.home.HomeFragment">

        <com.example.green_agriculture.components.SwiperView
            android:layout_width="match_parent"
            android:layout_height="154dp"
            app:index="@{viewModel.bannerIndex}"
            app:options="@{viewModel.bannerList}"
            app:outer_view_pager="@{outerViewPager}" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>